{
  "styles": {
    "surfaceCard": {
      "base": {
        "background": "#121B25",
        "cornerRadius": 12,
        "border": { "width": 1, "color": "#2C3A47" },
        "padding": [16, 16, 16, 16]
      }
    },
    "accentCard": {
      "extend": "$style.surfaceCard",
      "base": {
        "background": "#152033",
        "border": { "width": 1, "color": "#3A5F99" }
      }
    },
    "titleLabel": {
      "base": {
        "foreground": "#F2F6FB",
        "fontSize": 20
      }
    },
    "mutedLabel": {
      "base": {
        "foreground": "#8FA3B8",
        "fontSize": 13
      }
    }
  }
}
