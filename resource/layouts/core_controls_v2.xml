<Panel padding="14,14,14,14" spacing="8" cornerRadius="12" background="#0C1522" alignItems="stretch">
  <Label text="Core Controls V2" fontSize="20" color="#F3F8FF" />
  <Label text="Left: Progress / List / Combo. Right: TabControl (no wrap)." fontSize="12" color="#B8C8D9" />

  <Panel direction="row" spacing="10" background="#0C1522" alignItems="start">
    <Panel background="#122032" cornerRadius="10" padding="10,10,10,10" spacing="6" width="300" flexShrink="0">
      <Label text="ProgressBar" fontSize="13" color="#E9F2FD" />
      <ProgressBar label="CPU" min="0" max="100" value="62" step="2" fillColor="#4E7BFF" />
      <ProgressBar label="Memory" min="0" max="100" value="44" step="2" fillColor="#59C297" />
      <ProgressBar label="Disk" min="0" max="100" value="78" step="2" fillColor="#FF9B5A" />

      <Label text="ListBox" fontSize="13" color="#E9F2FD" />
      <ListBox
        items="Inbox|Backlog|In Progress|Ready For QA|Blocked|Done|Archived"
        selectedIndex="2"
        height="120"
        itemHeight="24" />

      <Label text="ComboBox" fontSize="13" color="#E9F2FD" />
      <ComboBox
        items="North America|Europe|Asia Pacific|Latin America|Middle East"
        selectedIndex="1"
        maxVisibleItems="5"
        headerHeight="30" />
    </Panel>

    <Panel background="#122032" cornerRadius="10" padding="10,10,10,10" spacing="6" flexGrow="1" minWidth="340" flexShrink="1">
      <Label text="TabControl" fontSize="13" color="#E9F2FD" />
      <TabControl tabs="Overview|Metrics|Tasks" selectedIndex="0" minHeight="220" headerHeight="30">
        <Panel padding="10,10,10,10" spacing="6" background="#0F1A26" alignItems="stretch">
          <Label text="Overview: status and basic inputs." fontSize="12" color="#D7E4F1" />
          <TextInput text="Release Candidate 1" />
          <Checkbox text="Enable notifications" checked="true" />
          <RadioButton text="Stable Channel" group="release-track" checked="true" />
          <RadioButton text="Preview Channel" group="release-track" />
        </Panel>
        <Panel padding="10,10,10,10" spacing="6" background="#0F1A26" alignItems="stretch">
          <Label text="Metrics: Slider + ProgressBar." fontSize="12" color="#D7E4F1" />
          <Slider label="Satisfaction" min="0" max="10" value="7" step="1" highlightColor="#4E7BFF" />
          <Slider label="Volume" min="0" max="100" value="42" step="1" highlightColor="#59C297" />
          <ProgressBar label="Completion" min="0" max="100" value="81" fillColor="#4C8DF8" />
          <ProgressBar label="Accuracy" min="0" max="100" value="93" fillColor="#59C297" />
        </Panel>
        <Panel padding="10,10,10,10" spacing="6" background="#0F1A26" alignItems="stretch">
          <Label text="Tasks: nested list and combo." fontSize="12" color="#D7E4F1" />
          <ListBox items="Design review|Implement parser|Write docs|Run validation|Create release tag" selectedIndex="1" height="100" itemHeight="24" />
          <ComboBox items="Low|Medium|High|Critical" selectedIndex="2" maxVisibleItems="4" headerHeight="30" />
        </Panel>
      </TabControl>
    </Panel>
  </Panel>
</Panel>
