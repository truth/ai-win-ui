<Panel padding="22,22,22,22" spacing="14" cornerRadius="16" background="#0C1522" alignItems="stretch">
  <Label text="Core Controls V2 Validation" fontSize="28" color="#F3F8FF" />
  <Label text="ProgressBar, ListBox, ComboBox, and TabControl interaction checks." fontSize="14" color="#B8C8D9" />

  <Panel direction="row" spacing="12" background="#0C1522" alignItems="stretch" wrap="wrap">
    <Panel background="#122032" cornerRadius="12" padding="12,12,12,12" spacing="10" width="360">
      <Label text="ProgressBar" fontSize="16" color="#E9F2FD" />
      <ProgressBar label="CPU" min="0" max="100" value="62" step="2" fillColor="#4E7BFF" />
      <ProgressBar label="Memory" min="0" max="100" value="44" step="2" fillColor="#59C297" />
      <ProgressBar label="Disk" min="0" max="100" value="78" step="2" fillColor="#FF9B5A" />

      <Label text="ListBox (Up/Down, mouse click)" fontSize="16" color="#E9F2FD" />
      <ListBox
        items="Inbox|Backlog|In Progress|Ready For QA|Blocked|Done|Archived"
        selectedIndex="2"
        height="188" />

      <Label text="ComboBox (Enter/Space to expand)" fontSize="16" color="#E9F2FD" />
      <ComboBox
        items="North America|Europe|Asia Pacific|Latin America|Middle East"
        selectedIndex="1"
        maxVisibleItems="5"
        height="178" />
    </Panel>

    <Panel background="#122032" cornerRadius="12" padding="12,12,12,12" spacing="10" flexGrow="1" minWidth="380">
      <Label text="TabControl (Left/Right to switch tabs)" fontSize="16" color="#E9F2FD" />
      <TabControl tabs="Overview|Metrics|Tasks" selectedIndex="0" height="430">
        <Panel padding="12,12,12,12" spacing="8" background="#0F1A26" alignItems="stretch">
          <Label text="Overview tab: basic status and input controls." fontSize="14" color="#D7E4F1" />
          <TextInput text="Release Candidate 1" />
          <Checkbox text="Enable notifications" checked="true" />
          <RadioButton text="Stable Channel" group="release-track" checked="true" />
          <RadioButton text="Preview Channel" group="release-track" />
        </Panel>
        <Panel padding="12,12,12,12" spacing="8" background="#0F1A26" alignItems="stretch">
          <Label text="Metrics tab: Slider and ProgressBar stay keyboard-usable." fontSize="14" color="#D7E4F1" />
          <Slider label="Satisfaction" min="0" max="10" value="7" step="1" />
          <ProgressBar label="Completion" min="0" max="100" value="81" fillColor="#4C8DF8" />
          <ProgressBar label="Accuracy" min="0" max="100" value="93" fillColor="#59C297" />
        </Panel>
        <Panel padding="12,12,12,12" spacing="8" background="#0F1A26" alignItems="stretch">
          <Label text="Tasks tab: list and combo can be tested in nested containers." fontSize="14" color="#D7E4F1" />
          <ListBox items="Design review|Implement parser|Write docs|Run validation|Create release tag" selectedIndex="1" height="190" />
          <ComboBox items="Low|Medium|High|Critical" selectedIndex="2" maxVisibleItems="4" height="150" />
        </Panel>
      </TabControl>
    </Panel>
  </Panel>
</Panel>
