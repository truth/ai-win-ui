<Panel direction="column" margin="20,20,20,20" alignItems="stretch" background="#1A2431" padding="20,20,20,20" width="600" height="400">
    <Label text="Hover over the panels to see cursor changes" fontSize="16" color="#FFFFFF" margin="0,0,0,20" />
    
    <Panel direction="row" height="100" margin="0,0,0,20" spacing="10">
        <Panel flex-grow="1" flex-basis="0" background="#3A4B5D" cornerRadius="8" cursor="hand" alignItems="center" justifyContent="center">
            <Label text="Cursor: Hand" color="#FFFFFF" />
        </Panel>
        
        <Panel flex-grow="1" flex-basis="0" background="#3A4B5D" cornerRadius="8" cursor="wait" alignItems="center" justifyContent="center">
            <Label text="Cursor: Wait" color="#FFFFFF" />
        </Panel>
        
        <Panel flex-grow="1" flex-basis="0" background="#3A4B5D" cornerRadius="8" cursor="forbidden" alignItems="center" justifyContent="center">
            <Label text="Cursor: Forbidden" color="#FFFFFF" />
        </Panel>
    </Panel>
    
    <Label text="Drag files here (Note: UI logic needed to show dropped files)" fontSize="16" color="#FFFFFF" margin="0,0,0,20" />
    
    <ScrollViewer flex-grow="1" background="#2A3B4D" cornerRadius="8" scrollY="true">
        <Panel allowDrop="true" background="#00000000" cursor="auto" direction="row" wrap="wrap" alignItems="flex-start" alignContent="flex-start" padding="15,15,15,30" spacing="10">
            <Label text="Drop files here..." fontSize="20" color="#AAAAAA" />
        </Panel>
    </ScrollViewer>
</Panel>
