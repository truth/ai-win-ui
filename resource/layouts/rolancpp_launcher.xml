    <!-- App 10: High-Logic F... -->
    <Panel direction="column" alignItems="center" spacing="12" width="104">
      <Panel width="88" height="88" background="#FFFFFF" cornerRadius="18" justifyContent="center" alignItems="center" shadowBlur="20" shadowOffsetY="8" shadowColor="#0000001A">
         <Panel width="48" height="48" background="#1C5FB1" cornerRadius="14" justifyContent="center" alignItems="center">
            <Label text="F" fontSize="24" color="#FFFFFF" />
         </Panel>
      </Panel>
      <Label text="High-Logic F..." fontSize="13" color="#555555" />
    </Panel>

    <!-- App 11: Redis Insight -->
    <Panel direction="column" alignItems="center" spacing="12" width="104">
      <Panel width="88" height="88" background="#FFFFFF" cornerRadius="18" justifyContent="center" alignItems="center" shadowBlur="20" shadowOffsetY="8" shadowColor="#0000001A">
         <Panel width="48" height="48" background="#111111" cornerRadius="14" justifyContent="center" alignItems="center">
            <Label text="R" fontSize="24" color="#D82C20" />
         </Panel>
      </Panel>
      <Label text="Redis Insight" fontSize="13" color="#555555" />
    </Panel>
  </Panel>
</Panel>
