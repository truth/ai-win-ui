{
  "type": "Panel",
  "props": {
    "padding": "$spacing.xl",
    "spacing": "$spacing.lg",
    "cornerRadius": "$radius.xl",
    "background": "#151515",
    "alignItems": "stretch",
    "justifyContent": "start"
  },
  "children": [
    {
      "type": "Label",
      "props": {
        "text": "Yoga-backed Vertical Stack",
        "fontSize": "$fontSize.3xl",
        "color": "#F5F5F5"
      }
    },
    {
      "type": "Label",
      "props": {
        "text": "This sample demonstrates flexGrow, flexBasis, and Spacer in the current Panel bridge.",
        "fontSize": 15,
        "color": "#B7B7B7",
        "margin": [0, 0, 0, 6]
      }
    },
    {
      "type": "Panel",
      "props": {
        "height": 620,
        "padding": [20, 20, 20, 20],
        "spacing": 14,
        "cornerRadius": "$radius.xl",
        "background": "#1E1E1E",
        "alignItems": "stretch"
      },
      "children": [
        {
          "type": "Panel",
          "props": {
            "height": 96,
            "padding": [18, 16, 18, 16],
            "spacing": 6,
            "cornerRadius": "$radius.lg",
            "background": "#242424",
            "alignItems": "start"
          },
          "children": [
            {
              "type": "Label",
              "props": {
                "text": "Release Checklist",
                "fontSize": 20,
                "color": "#FFFFFF"
              }
            },
            {
              "type": "Label",
              "props": {
                "text": "The gallery keeps a fixed block height, the spacer grows, and the action tray stays pinned to the bottom.",
                "fontSize": "$fontSize.base",
                "color": "#C8C8C8"
              }
            }
          ]
        },
        {
          "type": "Grid",
          "props": {
            "height": 160,
            "columns": 4,
            "spacing": "$spacing.md",
            "rowHeight": 136,
            "cornerRadius": "$radius.lg",
            "padding": [0, 12, 0, 12],
            "background": "#161616"
          },
          "children": [
            { "type": "Image", "props": { "source": "images/img1.jpg", "cornerRadius": 10 } },
            { "type": "Image", "props": { "source": "images/3d-design_9390515.png", "cornerRadius": 10 } },
            { "type": "Image", "props": { "source": "images/ai_10439488.png", "cornerRadius": 10 } },
            { "type": "Image", "props": { "source": "images/airplane_10521325.png", "cornerRadius": 10 } }
          ]
        },
        {
          "type": "Panel",
          "props": {
            "padding": "$spacing.lg",
            "spacing": "$spacing.sm",
            "cornerRadius": "$radius.lg",
            "background": "#202A35",
            "alignItems": "stretch"
          },
          "children": [
            {
              "type": "Label",
              "props": {
                "text": "Flex card",
                "fontSize": "$fontSize.xl",
                "color": "#F5F5F5"
              }
            },
            {
              "type": "Label",
              "props": {
                "text": "This card keeps its intrinsic height and lets the spacer absorb the remaining vertical room.",
                "fontSize": "$fontSize.base",
                "color": "#C7D2E2"
              }
            },
            {
              "type": "TextInput",
              "props": {
                "text": "Focus the next milestone...",
                "fontSize": "$fontSize.base",
                "background": "#16202A",
                "textColor": "#FFFFFF",
                "cornerRadius": "$radius.md"
              }
            }
          ]
        },
        {
          "type": "Panel",
          "props": {
            "direction": "row",
            "padding": [14, 14, 14, 14],
            "spacing": "$spacing.md",
            "cornerRadius": "$radius.lg",
            "background": "#1A2330",
            "alignItems": "center"
          },
          "children": [
            {
              "type": "Label",
              "props": {
                "text": "Row toolbar:",
                "fontSize": 15,
                "color": "#F5F5F5"
              }
            },
            {
              "type": "Button",
              "props": {
                "text": "Preview",
                "width": 120,
                "height": 38,
                "fontSize": "$fontSize.base",
                "cornerRadius": "$radius.md"
              }
            },
            {
              "type": "Button",
              "props": {
                "text": "Publish",
                "width": 120,
                "height": 38,
                "fontSize": "$fontSize.base",
                "background": "#2D6CDF",
                "cornerRadius": "$radius.md"
              }
            },
            {
              "type": "Spacer",
              "props": {
                "flexGrow": 1,
                "flexBasis": 0
              }
            },
            {
              "type": "Label",
              "props": {
                "text": "3 tasks left",
                "fontSize": "$fontSize.base",
                "color": "#AFC3DA"
              }
            }
          ]
        },
        {
          "type": "Spacer",
          "props": {
            "flexGrow": 1,
            "flexBasis": 0
          }
        },
        {
          "type": "Panel",
          "props": {
            "padding": "$spacing.lg",
            "spacing": 10,
            "cornerRadius": "$radius.lg",
            "background": "#242424",
            "alignItems": "stretch"
          },
          "children": [
            {
              "type": "Label",
              "props": {
                "text": "Pinned action tray",
                "fontSize": 17,
                "color": "#FFFFFF"
              }
            },
            {
              "type": "Button",
              "props": {
                "text": "Primary Action",
                "height": 42,
                "fontSize": 15,
                "background": "#2D6CDF",
                "cornerRadius": "$radius.md"
              },
              "events": {
                "onClick": "primaryAction"
              }
            },
            {
              "type": "Button",
              "props": {
                "text": "Secondary Action",
                "height": 42,
                "fontSize": 15,
                "cornerRadius": "$radius.md"
              },
              "events": {
                "onClick": "secondaryAction"
              }
            }
          ]
        }
      ]
    }
  ]
}
