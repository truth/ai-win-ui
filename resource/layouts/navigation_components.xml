<Panel padding="14,14,14,14" spacing="8" cornerRadius="12" background="#0D1521" alignItems="stretch">
  <Label text="Navigation Components" fontSize="20" color="#F2F7FF" />
  <Label text="Left shell. Right: ListView + TreeView wrap like flex; pill XY scrollbars when content overflows." fontSize="12" color="#B8C8D9" />

  <Panel direction="row" spacing="10" background="#0D1521" alignItems="start">
    <!-- Left: compact shell + context -->
    <Panel background="#122032" cornerRadius="10" padding="10,10,10,10" spacing="6" width="280" flexShrink="0" alignItems="stretch">
      <Label text="Shell" fontSize="13" color="#E9F2FD" />
      <MenuStrip
        items="File|Edit|View|Project|Help"
        icons="icons/check.svg|icons/arrow-right.svg|icons/star.svg|icons/check.svg|icons/arrow-right.svg"
        selectedIndex="2"
        stripHeight="28"
        background="#132232"
        selectedBackground="#2D567C" />
      <ToolStrip
        items="New|Open|Save|Run|Inspect|Publish"
        icons="icons/check.svg|icons/arrow-right.svg|icons/star.svg|icons/check.svg|icons/arrow-right.svg|icons/star.svg"
        selectedIndex="3"
        stripHeight="32"
        background="#132232"
        buttonBackground="#1A3044"
        selectedBackground="#315E88" />

      <Label text="ContextMenu" fontSize="13" color="#E9F2FD" />
      <ContextMenu
        items="Open|Open With...|Rename|Duplicate|Move To Archive|Delete"
        icons="icons/check.svg|icons/arrow-right.svg|icons/star.svg|icons/check.svg|icons/arrow-right.svg|icons/star.svg"
        selectedIndex="1"
        itemHeight="24"
        height="150" />

      <StatusStrip
        items="Ready|Nav validation|Wheel on lists"
        stripHeight="26" />
    </Panel>

    <!-- Right: wrap ListView / TreeView (flex-wrap style). Window V-scroll when stack is tall. -->
    <Panel direction="row" spacing="10" background="#0D1521" alignItems="stretch" flexGrow="1" minWidth="280" flexShrink="1" wrap="wrap">
      <Panel background="#0F1A26" cornerRadius="10" padding="10,10,10,10" spacing="6" flexGrow="1" flexBasis="280" minWidth="260" minHeight="220" alignItems="stretch">
        <Label text="ListView (wheel / Shift+wheel)" fontSize="13" color="#E9F2FD" />
        <ListView
          columns="Name|Role|Region|Status"
          columnWidths="140|150|110|110"
          rows="Ava Carter|Product Designer|APAC|Online;Noah Kim|Frontend Engineer|NA|In Review;Mia Chen|Data Analyst|EMEA|Online;Liam Patel|QA Engineer|APAC|Blocked;Emma Garcia|PM|NA|Online;Ethan Rossi|Backend Engineer|EMEA|Offline;Sophia Diaz|UX Researcher|LATAM|Online;Lucas Brown|DevOps Engineer|NA|Online;Olivia Park|Tech Writer|APAC|Drafting;Mason Hill|Support Lead|NA|Escalated;Amelia Ng|Mobile Engineer|APAC|Online;Henry Cho|Platform|EMEA|Online"
          selectedIndex="2"
          flexGrow="1"
          minHeight="200"
          height="240"
          headerHeight="28"
          rowHeight="26" />
      </Panel>

      <Panel background="#0F1A26" cornerRadius="10" padding="10,10,10,10" spacing="6" flexGrow="1" flexBasis="280" minWidth="260" minHeight="220" alignItems="stretch">
        <Label text="TreeView (wheel scroll)" fontSize="13" color="#E9F2FD" />
        <TreeView
          items="Workspace/Design System/Typography;Workspace/Design System/Color Tokens;Workspace/Design System/Icon Set;Workspace/Frontend/Dashboard;Workspace/Frontend/Settings;Workspace/Backend/Auth Service;Workspace/Backend/Telemetry;Workspace/Backend/Reporting;Workspace/Docs/Architecture;Workspace/Docs/Release Notes;Workspace/QA/Regression Pack;Workspace/QA/Accessibility;Workspace/Infra/CI;Workspace/Infra/CD;Workspace/Infra/Monitoring"
          expandedAll="true"
          flexGrow="1"
          minHeight="200"
          height="240"
          itemHeight="24" />
      </Panel>
    </Panel>
  </Panel>
</Panel>
