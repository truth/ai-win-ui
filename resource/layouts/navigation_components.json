                      "Workspace/Frontend/Settings",
                      "Workspace/Backend/Auth Service",
                      "Workspace/Backend/Telemetry",
                      "Workspace/Backend/Reporting",
                      "Workspace/Docs/Architecture",
                      "Workspace/Docs/Release Notes",
                      "Workspace/QA/Regression Pack",
                      "Workspace/QA/Accessibility"
