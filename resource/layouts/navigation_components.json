                    "rows": [
                      ["Ava Carter", "Product Designer", "APAC", "Online"],
                      ["Noah Kim", "Frontend Engineer", "NA", "In Review"],
                      ["Mia Chen", "Data Analyst", "EMEA", "Online"],
                      ["Liam Patel", "QA Engineer", "APAC", "Blocked"],
                      ["Emma Garcia", "PM", "NA", "Online"],
                      ["Ethan Rossi", "Backend Engineer", "EMEA", "Offline"],
                      ["Sophia Diaz", "UX Researcher", "LATAM", "Online"],
                      ["Lucas Brown", "DevOps Engineer", "NA", "Online"],
                      ["Olivia Park", "Tech Writer", "APAC", "Drafting"],
                      ["Mason Hill", "Support Lead", "NA", "Escalated"]
                    ],
                    "selectedIndex": 2,
                    "flexGrow": 1,
                    "minHeight": 220
