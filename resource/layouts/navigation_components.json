                }
              ]
            },
            {
              "type": "Panel",
              "props": {
                "background": "#0F1A26",
                "cornerRadius": "$radius.lg",
                "padding": "$spacing.md",
                "spacing": 10,
                "flexGrow": 1,
                "minWidth": 340,
                "minHeight": 260
              },
              "children": [
                {
                  "type": "Label",
                  "props": {
                    "text": "TreeView",
                    "fontSize": "$fontSize.lg",
                    "color": "#E9F2FD"
