<Panel padding="14,14,14,14" spacing="8" cornerRadius="12" background="#0C1522" alignItems="stretch">
  <Label text="Advanced Inputs" fontSize="20" color="#F3F8FF" />
  <Label text="Left: Numeric + DateTime. Right: RichTextBox (no wrap)." fontSize="12" color="#B8C8D9" />

  <Panel direction="row" spacing="10" background="#0C1522" alignItems="start">
    <Panel background="#122032" cornerRadius="10" padding="10,10,10,10" spacing="6" width="320" flexShrink="0">
      <Label text="NumericUpDown" fontSize="13" color="#E9F2FD" />
      <NumericUpDown label="Quantity" min="0" max="100" value="12" step="1" />
      <NumericUpDown label="Opacity" min="0" max="1" value="0.75" step="0.05" decimalPlaces="2" />
      <NumericUpDown label="Temperature" min="-20" max="40" value="22" step="0.5" decimalPlaces="1" />

      <Label text="DateTimePicker" fontSize="13" color="#E9F2FD" />
      <DateTimePicker label="Date" mode="date" value="2026-07-15" />
      <DateTimePicker label="Time" mode="time" value="14:30" />
      <DateTimePicker label="DateTime" mode="dateTime" value="2026-07-15 18:45" />
      <DateTimePicker label="Full" mode="dateTime" value="2026-12-31 23:59:59" showSeconds="true" />
    </Panel>

    <Panel background="#122032" cornerRadius="10" padding="10,10,10,10" spacing="6" flexGrow="1" minWidth="340" flexShrink="1">
      <Label text="RichTextBox" fontSize="13" color="#E9F2FD" />
      <Label text="Enter=line. Ctrl+B bold, Ctrl+I italic." fontSize="11" color="#9BB0C3" />
      <RichTextBox
        height="160"
        text="Welcome to **RichTextBox** v1.\nSelect words and press Ctrl+B / Ctrl+I.\nPlain *italic* and **bold** markup is parsed at load." />
      <RichTextBox
        height="90"
        plainText="Plain text box (no markup). Type freely and format with Ctrl+B / Ctrl+I." />

      <Label text="Combo (opens upward near bottom)" fontSize="12" color="#E9F2FD" />
      <ComboBox
        items="Alpha|Bravo|Charlie|Delta|Echo|Foxtrot|Golf"
        selectedIndex="0"
        maxVisibleItems="6"
        headerHeight="30" />
    </Panel>
  </Panel>
</Panel>
