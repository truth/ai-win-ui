<!--
  Wave2 C4 Popup + S4 runtime theme switch.
  Uses $color.* so ApplyThemeDefaults / catalog rebind visibly changes surfaces.
  .\scripts\run_layout_demo.ps1 -Layout popup-theme
-->
<Panel name="root" direction="column" padding="24,24,24,24" spacing="16" background="$color.surface-0" alignItems="stretch">
  <Label name="title" text="Popup + Theme Demo (Wave2 C4 / S4)" fontSize="22" color="$color.fg-strong" />
  <Label name="hint" text="Popup: RenderOverlay + light-dismiss. Theme buttons reload tokens, re-parse catalog, rebind $style + $color." fontSize="13" color="$color.fg-muted" />

  <Panel name="row" direction="row" spacing="12" alignItems="center">
    <Popup
      name="demoPopup"
      triggerText="Open flyout"
      width="150"
      height="36"
      popupWidth="280"
      popupHeight="150"
      placement="below">
      <Label text="Generic Popup body (C4)" fontSize="15" color="$color.fg" />
      <Label text="Children layout in the overlay panel. Click outside or press Esc to dismiss." fontSize="12" color="$color.fg-muted" />
    </Popup>

    <ComboBox
      name="demoCombo"
      items="Alpha|Bravo|Charlie|Delta|Echo"
      selectedIndex="1"
      width="160"
      headerHeight="36"
      maxVisibleItems="4" />

    <Button name="themeDark" text="Theme: Dark" style="$style.primaryButton" onClick="applyTheme:themes/default.json" height="36" width="130" />
    <Button name="themeLight" text="Theme: Light" style="$style.primaryButton" onClick="applyTheme:themes/light.json" height="36" width="130" />
  </Panel>

  <Panel name="card" direction="column" padding="14,14,14,14" spacing="8" background="$color.surface-1" cornerRadius="10" alignItems="stretch">
    <Label name="cardTitle" text="Notes" fontSize="16" color="$color.fg-strong" />
    <Label text="• Popup + Combo share OverlayFlyout placement (C4)." fontSize="13" color="$color.fg" />
    <Label text="• applyTheme:* reloads Theme + StyleCatalog; $color surfaces and $style.primaryButton update." fontSize="13" color="$color.fg" />
    <Label text="• Hard-coded #hex still does not switch — prefer $color.* for skins." fontSize="13" color="$color.fg-muted" />
  </Panel>
</Panel>
